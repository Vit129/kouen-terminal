#!/bin/bash
# Block Info.plist from landing in non-version commits.
# Root cause: "fix: panel" (0f71782) accidentally staged Info.plist and reverted 3.10.0 → 3.9.5.

STAGED=$(git diff --cached --name-only)
if echo "$STAGED" | grep -q "Info.plist"; then
    MSG=$(cat "$1")
    if ! echo "$MSG" | grep -qiE "version|bump|release|build|3\.[0-9]+\.[0-9]+"; then
        echo ""
        echo "🛑  Info.plist is staged but this looks like a non-version commit."
        echo "    Message: \"$MSG\""
        echo ""
        echo "    Unstage it:  git restore --staged Apps/Harness/Sources/HarnessApp/Resources/Info.plist"
        echo "    Or add 'version' / 'bump' / build number to the message if intentional."
        echo ""
        exit 1
    fi
fi
